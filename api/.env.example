NODE_ENV=development

# ─── Banco de Dados ───────────────────────────────────────────────────────
DB_HOST=auth_db
DB_PORT=5432
DB_NAME=auth_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# ─── RabbitMQ ─────────────────────────────────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_JWT_SECRET

# ─── Comunicação Interna ──────────────────────────────────────────────────
INTERNAL_SERVICE_KEY=CHANGE_ME_INTERNAL_KEY

# ─── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Stripe (use suas chaves reais em .env, não aqui) ─────────────────────
STRIPE_SECRET_KEY=sk_test_xxx

# ─── Resend (email) ──────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx
EMAIL_FROM=noreply@example.com

# ─── Cloudinary ──────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── SMTP (opcional para notification-service) ───────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=CHANGE_ME_SMTP_PASS

# ─── MercadoPago (se usado) ──────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=CHANGE_ME_MERCADOPAGO_TOKEN

# ─── URLs dos Serviços (para API Gateway) ────────────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002
SEARCH_SERVICE_URL=http://search-service:3003
BOOKING_SERVICE_URL=http://booking-service:3004
PAYMENT_SERVICE_URL=http://payment-service:3005
ADMIN_SERVICE_URL=http://admin-service:3007

# ─── Ports (opcionais) ───────────────────────────────────────────────────
PORT_AUTH=3001
PORT_USER=3002
PORT_SEARCH=3003
PORT_BOOKING=3004
PORT_PAYMENT=3005
PORT_NOTIFICATION=3006
PORT_ADMIN=3007
PORT_GATEWAY=3000
